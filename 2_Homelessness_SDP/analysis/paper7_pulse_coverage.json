  "caveats": [
    "eviction_risk_share = (Very likely + Somewhat likely)/Total from housing3b 'Total' row; housing3b universe = renters 18+ NOT current on rental payments (i.e. share of behind renters who expect eviction).",
    "behind_on_rent_share = (caught up 'No')/Total from housing1b 'Total' row; housing1b universe = all renter-occupied HU 18+.",
    "Anchor row = first row where col0=='Total'. Column positions: 3b cols 2,3=Very/Somewhat likely, col1=Total; 1b col3='No' caught up, col1=Total. Verified header rows 4-5 stable across 2022/2023/2024 files.",
    "Cross-check: housing1b 'No' count == housing3b 'Total' count (same population), confirmed for US 2022 wk42 & 2024 cycle09.",
    "'-' suppressed cells treated as missing (blank in output).",
    "2022=weeks 42-51, 2023=weeks 52-63, 2024=cycles 01-09 (cycle naming replaced week naming in 2024)."
  ],
